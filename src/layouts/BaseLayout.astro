---
interface Props {
  title?: string;
}

const { title = 'PHC' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900">
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <a href="/" class="text-xl font-semibold">PHC</a>
          <nav class="flex items-center gap-6" aria-label="Main">
            <button
              type="button"
              class="inline-flex items-center justify-center rounded-lg p-2 text-gray-600 hover:bg-gray-100 md:hidden"
              aria-label="Toggle menu"
              aria-expanded="false"
              data-mobile-menu-toggle
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            <div class="hidden md:flex md:items-center md:gap-6" data-desktop-nav>
              <a href="/" class="text-sm font-medium text-gray-700 hover:text-gray-900">Home</a>
              <a href="/portfolio" class="text-sm font-medium text-gray-700 hover:text-gray-900">Portfolio</a>
            </div>
          </nav>
        </div>
        <div class="hidden border-t border-gray-200 py-2 md:hidden" data-mobile-menu aria-hidden="true">
          <a href="/" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Home</a>
          <a href="/portfolio" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Portfolio</a>
        </div>
      </div>
    </header>
    <main class="flex-1">
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>
    <footer class="border-t border-gray-200 py-6">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm text-gray-500">
          © {new Date().getFullYear()} PHC. <a href="/portfolio" class="hover:text-gray-700">Portfolio</a>
        </p>
      </div>
    </footer>
    <script>
      document.querySelector('[data-mobile-menu-toggle]')?.addEventListener('click', () => {
        const menu = document.querySelector('[data-mobile-menu]');
        const btn = document.querySelector('[data-mobile-menu-toggle]');
        if (!menu || !btn) return;
        const open = menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!open));
      });
    </script>
  </body>
</html>
