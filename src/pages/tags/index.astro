---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { slugify } from '@/lib/slug';
import { createBreadcrumbListSchema } from '@/lib/seo/jsonld';

const portfolio = await getCollection('portfolio');
const tagToSlug = new Map<string, string>();
const tagCounts = new Map<string, number>();

for (const entry of portfolio) {
  const tags = entry.data.tags ?? [];
  for (const tag of tags) {
    const s = slugify(tag);
    if (!s) continue;
    if (!tagToSlug.has(tag)) tagToSlug.set(tag, s);
    tagCounts.set(s, (tagCounts.get(s) ?? 0) + 1);
  }
}

const tagsWithCounts = Array.from(tagCounts.entries())
  .map(([slug, count]) => {
    const label = Array.from(tagToSlug.entries()).find(([, s]) => s === slug)?.[0] ?? slug;
    return { slug, label, count };
  })
  .sort((a, b) => b.count - a.count);

const siteEntry = await getEntry('site', 'index');
const tagsTitle = siteEntry?.data?.tagsTitle ?? 'Tags';
const site = Astro.url.origin || import.meta.env.SITE || "https://phandc.net";
const jsonLdNodes = [
  createBreadcrumbListSchema(site, [
    { name: "Home", path: "/" },
    { name: "Tags", path: "/tags" },
  ]),
];
---

<BaseLayout title={tagsTitle} jsonLdNodes={jsonLdNodes}>
  <div class="pt-8 space-y-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Tags</h1>
    <p class="text-gray-600 dark:text-gray-400">
      Browse portfolio items by tag.
    </p>
    <ul class="flex flex-wrap gap-3">
      {tagsWithCounts.map(({ slug, label, count }) => (
        <li>
          <a
            href={`/tags/${slug}`}
            class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-gray-50 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-primary hover:bg-primary/5 hover:text-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-primary dark:hover:bg-primary/10"
          >
            <span>{label}</span>
            <span class="rounded-full bg-gray-200 px-1.5 py-0.5 text-xs dark:bg-gray-700">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
