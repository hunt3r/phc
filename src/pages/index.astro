---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPage from '../components/blocks/hero-page.astro';
import { getEntry } from 'astro:content';

const homeEntry = await getEntry('home', 'index');
const data = homeEntry?.data;
const hero = data?.hero;
---

<BaseLayout title="Home">
  <HeroPage
    size={hero?.size ?? 'full'}
    eyebrow={hero?.eyebrow}
    tagline={hero?.tagline ?? 'Welcome to PHC'}
    subtitle={hero?.subtitle ?? 'Construction and renovation expertise.'}
    ctaPrimaryText={hero?.ctaPrimaryText}
    ctaPrimaryHref={hero?.ctaPrimaryHref}
    ctaSecondaryText={hero?.ctaSecondaryText}
    ctaSecondaryHref={hero?.ctaSecondaryHref}
    backgroundImage={typeof hero?.backgroundImage === 'string' ? hero.backgroundImage : undefined}
    overlayOpacity={hero?.overlayOpacity ?? 70}
    overlayColor={hero?.overlayColor ?? 'dark'}
  />
  <article class="space-y-16">

    {data?.about && (
      <section>
        <h2 class="text-2xl font-semibold text-gray-900">
          {data.about.heading ?? 'About Us'}
        </h2>
        <p class="mt-3 text-gray-600">
          {data.about.body ?? 'We deliver quality construction and renovation projects.'}
        </p>
      </section>
    )}

    {data?.contactCta && (
      <section class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center">
        <h2 class="text-xl font-semibold text-gray-900">
          {data.contactCta.heading ?? 'Get in Touch'}
        </h2>
        <p class="mt-2 text-gray-600">
          {data.contactCta.subtext ?? 'Ready to start your project? Contact us today.'}
        </p>
      </section>
    )}
  </article>
</BaseLayout>
