---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const homeEntry = await getEntry('home', 'index');
const data = homeEntry?.data;
---

<BaseLayout title="Home">
  <article class="space-y-16">
    <section class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
        {data?.hero?.tagline ?? 'Welcome to PHC'}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
        {data?.hero?.subtitle ?? 'Construction and renovation expertise.'}
      </p>
    </section>

    {data?.about && (
      <section>
        <h2 class="text-2xl font-semibold text-gray-900">
          {data.about.heading ?? 'About Us'}
        </h2>
        <p class="mt-3 text-gray-600">
          {data.about.body ?? 'We deliver quality construction and renovation projects.'}
        </p>
      </section>
    )}

    {data?.contactCta && (
      <section class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center">
        <h2 class="text-xl font-semibold text-gray-900">
          {data.contactCta.heading ?? 'Get in Touch'}
        </h2>
        <p class="mt-2 text-gray-600">
          {data.contactCta.subtext ?? 'Ready to start your project? Contact us today.'}
        </p>
      </section>
    )}
  </article>
</BaseLayout>
