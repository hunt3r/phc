---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPage from '../components/blocks/hero-page.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getEntry, getCollection } from 'astro:content';

const homeEntry = await getEntry('home', 'index');
const data = homeEntry?.data;
const hero = data?.hero;
const portfolioEntries = await getCollection('portfolio');

const latestProjects = [...portfolioEntries].sort((a, b) => {
  const orderA = (a.data as any).order ?? 999;
  const orderB = (b.data as any).order ?? 999;
  if (orderA !== orderB) return orderA - orderB;
  return ((a.data as any).title ?? '').localeCompare((b.data as any).title ?? '');
}).slice(0, 3);

const ogDescription = hero?.subtitle ?? (typeof data?.about?.body === 'string' ? data.about.body.slice(0, 160).trim() : undefined) ?? "PH&C facilitates Real Estate Development as the tri-state area's premiere Owner's Representation, Construction Management, and Fee Development firm.";
const ogImage = typeof hero?.backgroundImage === 'string' ? hero.backgroundImage : undefined;
---

<BaseLayout title="Home" description={ogDescription} image={ogImage}>
  <HeroPage
    size={hero?.size ?? 'full'}
    eyebrow={hero?.eyebrow}
    tagline={hero?.tagline ?? 'Welcome to PHC'}
    subtitle={hero?.subtitle ?? 'Construction and renovation expertise.'}
    ctaPrimaryText={hero?.ctaPrimaryText}
    ctaPrimaryHref={hero?.ctaPrimaryHref}
    ctaSecondaryText={hero?.ctaSecondaryText}
    ctaSecondaryHref={hero?.ctaSecondaryHref}
    backgroundImage={typeof hero?.backgroundImage === 'string' ? hero.backgroundImage : undefined}
    overlayOpacity={hero?.overlayOpacity ?? 70}
    overlayColor={hero?.overlayColor ?? 'dark'}
  />
  <article class="pt-16 space-y-16 sm:pt-20">

    {latestProjects.length > 0 && (
      <section>
        <div class="mb-8 text-center">
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 sm:text-3xl">
            Latest projects
          </h2>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Recent construction and renovation work from the PH&amp;C team.
          </p>
        </div>
        <div class="grid w-full gap-6 grid-cols-1 sm:grid-cols-[repeat(auto-fit,minmax(260px,1fr))]">
          {latestProjects.map((entry) => (
            <ProjectCard
              title={(entry.data as any).title}
              description={(entry.data as any).description ?? ''}
              href={`/portfolio/${entry.id}`}
              imageSrc={(entry.data as any).image}
              imageAlt={(entry.data as any).title}
              tags={Array.isArray((entry.data as any).tags) ? (entry.data as any).tags : ((entry.data as any).category ? [(entry.data as any).category] : [])}
              date={(entry.data as any).year}
            />
          ))}
        </div>
      </section>
    )}

    {data?.about && (
      <section>
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">
          {data.about.heading ?? 'About Us'}
        </h2>
        <p class="mt-3 text-gray-600 dark:text-gray-400">
          {data.about.body ?? 'We deliver quality construction and renovation projects.'}
        </p>
      </section>
    )}

    {data?.contactCta && (
      <section class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
          {data.contactCta.heading ?? 'Get in Touch'}
        </h2>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          {data.contactCta.subtext ?? 'Ready to start your project? Contact us today.'}
        </p>
      </section>
    )}
  </article>
</BaseLayout>
