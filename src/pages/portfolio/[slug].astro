---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import PortfolioGallery from '../../components/PortfolioGallery.astro';
import { getImageUrl } from '@/lib/cloudinary';
import { slugify } from '@/lib/slug';
import { getCategoryBySlug } from '@/data/categories';
import {
  createBreadcrumbListSchema,
  createPortfolioCreativeWorkSchema,
  toAbsoluteUrl,
} from '@/lib/seo/jsonld';

export async function getStaticPaths() {
  const portfolio = await getCollection('portfolio');
  return portfolio.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const heroImageUrl = entry.data.image ? getImageUrl(entry.data.image, { width: 1200, quality: 'auto:eco' }) : undefined;

// Use gallery from frontmatter, or fall back to hero image so the gallery section always shows when we have an image
const galleryImages =
  entry.data.gallery && entry.data.gallery.length > 0
    ? entry.data.gallery
    : entry.data.image
      ? [{ src: entry.data.image, alt: entry.data.title ?? '' }]
      : [];

const ogDescription = entry.data.description ? entry.data.description.slice(0, 160).trim() : undefined;
const site = Astro.url.origin || import.meta.env.SITE || "https://phandc.net";
const pageUrl = Astro.url.href;
const jsonLdNodes = [
  createBreadcrumbListSchema(site, [
    { name: "Home", path: "/" },
    { name: "Portfolio", path: "/portfolio" },
    { name: entry.data.title, url: pageUrl },
  ]),
  createPortfolioCreativeWorkSchema(site, {
    url: pageUrl,
    name: entry.data.title,
    description: ogDescription,
    image: entry.data.image ? toAbsoluteUrl(entry.data.image, site) : undefined,
    category: entry.data.category,
    date: entry.data.date,
    location: entry.data.location,
    client: entry.data.client,
    tags: entry.data.tags,
  }),
];
---

<BaseLayout title={entry.data.title} description={ogDescription} image={entry.data.image} jsonLdNodes={jsonLdNodes}>
  <article class="pt-8 space-y-8">
    <header class="space-y-3">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="text-lg text-gray-600 dark:text-gray-300">
          {entry.data.description}
        </p>
      )}
      <dl class="mt-2 grid gap-4 text-sm text-gray-600 dark:text-gray-300 sm:grid-cols-3">
        {entry.data.location && (
          <div>
            <dt class="font-medium text-gray-900 dark:text-gray-100">Location</dt>
            <dd>{entry.data.location}</dd>
          </div>
        )}
        {entry.data.client && (
          <div>
            <dt class="font-medium text-gray-900 dark:text-gray-100">Client</dt>
            <dd>{entry.data.client}</dd>
          </div>
        )}
        {entry.data.date && (
          <div>
            <dt class="font-medium text-gray-900 dark:text-gray-100">Date</dt>
            <dd>{entry.data.date}</dd>
          </div>
        )}
      </dl>
      <div class="mt-2 flex flex-wrap items-center gap-2">
        {entry.data.category && (() => {
          const catSlug = slugify(entry.data.category!);
          const cat = getCategoryBySlug(catSlug) ?? { slug: catSlug, label: entry.data.category! };
          return (
            <a
              href={`/category/${cat.slug}`}
              class="inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-2.5 py-0.5 text-xs font-medium text-gray-700 transition hover:border-primary hover:bg-primary/5 hover:text-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:border-primary dark:hover:bg-primary/10"
            >
              {cat.label}
            </a>
          );
        })()}
        {entry.data.tags && entry.data.tags.length > 0 && entry.data.tags.map((tag: string) => (
          <a
            href={`/tags/${slugify(tag)}`}
            class="inline-flex items-center rounded-full border border-gray-200 bg-gray-50 px-2.5 py-0.5 text-xs font-medium text-gray-700 transition hover:border-primary hover:bg-primary/5 hover:text-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:border-primary dark:hover:bg-primary/10"
          >
            {tag}
          </a>
        ))}
      </div>
      {heroImageUrl && (
        <img
          src={heroImageUrl}
          alt={entry.data.title}
          class="mt-4 w-full rounded-lg object-cover"
        />
      )}
    </header>

    <section class="prose-content">
      <Content />
    </section>

    {galleryImages.length > 0 && (
      <PortfolioGallery images={galleryImages} galleryId={entry.id} />
    )}
  </article>
</BaseLayout>
