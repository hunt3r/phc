---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImageUrl } from '@/lib/cloudinary';

const portfolio = await getCollection('portfolio');
const sorted = portfolio.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<BaseLayout title="Portfolio">
  <div class="pt-8 space-y-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Portfolio</h1>
    <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((entry) => (
        <li>
          <a
            href={`/portfolio/${entry.id}`}
            class="block overflow-hidden rounded-lg border border-gray-200 bg-white transition hover:border-gray-300 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:hover:border-gray-600"
          >
            {entry.data.image && (
              <img
                src={getImageUrl(entry.data.image, { width: 480, quality: 'auto:eco' })}
                alt=""
                class="h-48 w-full object-cover"
                loading="lazy"
              />
            )}
            <div class="p-4">
              <h2 class="font-semibold text-gray-900 dark:text-gray-100">{entry.data.title}</h2>
              {entry.data.description && (
                <p class="mt-1 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">{entry.data.description}</p>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
