---
import { getImageUrl } from '@/lib/cloudinary';

interface Props {
  name: string;
  title: string;
  bio: string;
  /** Optional profile photo path or Cloudinary URL */
  image?: string;
  /** Optional: show as in memoriam (e.g. subtitle under title) */
  inMemoriam?: string;
}

const { name, title, bio, image, inMemoriam } = Astro.props;
const imageUrl = image ? getImageUrl(image, { width: 200, height: 200, crop: 'fill' }) : undefined;
const paragraphs = bio.split(/\n\n+/).filter(Boolean);
const initials = name
  .split(/\s+/)
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<div class="grid grid-cols-1 sm:grid-cols-[12rem_1fr] gap-4 sm:gap-6 overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-900">
  <div class="flex flex-col items-center justify-center gap-3 min-w-0 sm:min-h-0">
    {(imageUrl || initials) && (
      <div class="w-24 h-24 sm:w-28 sm:h-28 shrink-0 rounded-full overflow-hidden bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-xl sm:text-2xl font-semibold text-gray-500 dark:text-gray-400">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt=""
            class="h-full w-full object-cover"
            width="112"
            height="112"
            loading="lazy"
          />
        ) : (
          initials
        )}
      </div>
    )}
    <div class="text-center">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{name}</h3>
      <p class="mt-0.5 text-sm text-primary">{title}</p>
      {inMemoriam && (
        <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">{inMemoriam}</p>
      )}
    </div>
  </div>
  <div class="space-y-2 text-sm text-gray-600 dark:text-gray-300 min-w-0">
    {paragraphs.map((para) => (
      <p>{para}</p>
    ))}
  </div>
</div>
