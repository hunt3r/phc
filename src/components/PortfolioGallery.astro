---
import { getImageUrl } from "@/lib/cloudinary";

interface Image {
  src: string
  alt?: string
}

interface Props {
  images: Image[]
  /** Optional unique id when multiple galleries exist on one page (e.g. portfolio slug). */
  galleryId?: string
}

const { images, galleryId = "default" } = Astro.props as Props
const rootId = `portfolio-gallery-${galleryId}`
const lightboxId = `portfolio-lightbox-${galleryId}`
const lightboxImageId = `portfolio-lightbox-image-${galleryId}`

const THUMB_OPTIONS = { width: 400, quality: "auto:eco" as const };
const LIGHTBOX_OPTIONS = { width: 1200, quality: "auto:eco" as const };
const thumbImages = images.map((img) => ({ src: getImageUrl(img.src, THUMB_OPTIONS), alt: img.alt }));
const lightboxImages = images.map((img) => ({ src: getImageUrl(img.src, LIGHTBOX_OPTIONS), alt: img.alt }));
---

{images && images.length > 0 && (
  <section class="mt-8">
    <h2 class="mb-4 text-lg font-semibold text-gray-900">Project gallery</h2>
    <div
      id={rootId}
      class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3"
      data-images={JSON.stringify(lightboxImages)}
      data-gallery-id={galleryId}
    >
      {thumbImages.map((image, index) => (
        <button
          type="button"
          class="group relative overflow-hidden rounded-lg border border-gray-200 bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary dark:border-gray-700 dark:bg-gray-800"
          data-index={index}
        >
          <img
            src={image.src}
            alt={image.alt || ""}
            loading="lazy"
            class="h-40 w-full object-cover transition-transform duration-200 group-hover:scale-105"
          />
        </button>
      ))}
    </div>

    <div
      id={lightboxId}
      class="pointer-events-none fixed inset-0 z-40 flex items-center justify-center bg-black/70 opacity-0 transition-opacity duration-150"
      role="dialog"
      aria-modal="true"
      aria-label="Image gallery"
      aria-hidden="true"
      hidden
      inert
    >
      <div class="relative mx-4 max-h-[90vh] max-w-4xl rounded-lg bg-black/80 p-4 text-white shadow-xl" id={`${lightboxId}-focus-root`} tabindex="-1">
        <button
          type="button"
          class="absolute right-3 top-3 rounded-full bg-white/10 px-2 py-1 text-sm font-medium hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          data-role="close"
          aria-label="Close gallery"
        >
          Close
        </button>
        <button
          type="button"
          class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-2 py-1 text-sm hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          data-role="prev"
          aria-label="Previous image"
        >
          ‹
        </button>
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 px-2 py-1 text-sm hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          data-role="next"
          aria-label="Next image"
        >
          ›
        </button>
        <div class="flex items-center justify-center">
          <img
            id={lightboxImageId}
            src=""
            alt=""
            class="max-h-[75vh] w-auto max-w-full rounded-md object-contain"
          />
        </div>
        <div aria-live="polite" aria-atomic="true" class="sr-only" data-role="counter"></div>
      </div>
    </div>
  </section>
)}

<script>
  function initGalleries() {
  const galleryRoots = document.querySelectorAll("[data-gallery-id]");
  if (!galleryRoots.length) return;

  function getFocusables(container) {
    const sel = 'button:not([disabled]), [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
    return Array.from(container.querySelectorAll(sel));
  }

  function trapFocus(e, focusRoot) {
    if (e.key !== "Tab") return;
    const focusables = getFocusables(focusRoot);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  galleryRoots.forEach((galleryRoot) => {
    const galleryId = galleryRoot.dataset.galleryId ?? "default";
    const lightbox = document.getElementById(`portfolio-lightbox-${galleryId}`);
    const lightboxImg = document.getElementById(`portfolio-lightbox-image-${galleryId}`);
    const focusRoot = document.getElementById(`portfolio-lightbox-${galleryId}-focus-root`);
    const counterEl = lightbox?.querySelector("[data-role=counter]");
    if (!lightbox || !lightboxImg || !focusRoot) return;

    const images = JSON.parse(galleryRoot.dataset.images || "[]");
    let currentIndex = 0;
    let lastActiveThumb = null;
    let keyHandler = null;

    function updateCounter() {
      if (counterEl && images.length) counterEl.textContent = `Image ${currentIndex + 1} of ${images.length}`;
    }

    function openLightbox(index, thumb) {
      currentIndex = index;
      lastActiveThumb = thumb;
      const img = images[currentIndex];
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt || "";
      updateCounter();
      lightbox.removeAttribute("hidden");
      lightbox.removeAttribute("inert");
      lightbox.classList.remove("pointer-events-none");
      lightbox.setAttribute("aria-hidden", "false");
      lightbox.classList.add("opacity-100");
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", (keyHandler = (e) => {
        if (e.key === "Escape") {
          e.preventDefault();
          closeLightbox();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          showNext(1);
        } else if (e.key === "ArrowLeft") {
          e.preventDefault();
          showNext(-1);
        } else if (e.key === "Tab") {
          trapFocus(e, focusRoot);
        }
      }));
      focusRoot.focus();
    }

    function closeLightbox() {
      lightbox.classList.add("pointer-events-none");
      lightbox.setAttribute("aria-hidden", "true");
      lightbox.classList.remove("opacity-100");
      lightbox.setAttribute("inert", "");
      lightbox.setAttribute("hidden", "");
      document.body.style.overflow = "";
      if (keyHandler) document.removeEventListener("keydown", keyHandler);
      keyHandler = null;
      if (lastActiveThumb) lastActiveThumb.focus();
    }

    function showNext(delta) {
      if (images.length === 0) return;
      currentIndex = (currentIndex + delta + images.length) % images.length;
      const img = images[currentIndex];
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt || "";
      updateCounter();
    }

    galleryRoot.addEventListener("click", (event) => {
      const target = event.target;
      if (!target) return;
      const button = target.closest("button[data-index]");
      if (!button) return;
      const index = Number(button.dataset.index || "0");
      openLightbox(index, button);
    });

    lightbox.addEventListener("click", (event) => {
      const target = event.target;
      if (!target) return;
      const control = target.closest("[data-role]");
      if (control?.dataset.role === "close") {
        closeLightbox();
        return;
      }
      if (control?.dataset.role === "next") {
        showNext(1);
        return;
      }
      if (control?.dataset.role === "prev") {
        showNext(-1);
        return;
      }
      if (target === lightbox) {
        closeLightbox();
      }
    });
  });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGalleries);
  } else {
    initGalleries();
  }
</script>

