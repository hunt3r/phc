---
interface Props {
  title: string
  description: string
  href: string
  imageSrc?: string
  imageAlt?: string
  tags?: string[]
  date?: string
  class?: string
}

const {
  title,
  description,
  href,
  imageSrc,
  imageAlt,
  tags = [],
  date,
  class: className,
} = Astro.props as Props
---

<a
  href={href}
  class={`group flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white text-gray-900 shadow-sm transition-all duration-150 hover:-translate-y-0.5 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 ${className ?? ""}`}
>
  {imageSrc && (
    <div class="relative aspect-[16/9] w-full overflow-hidden bg-gray-100 dark:bg-gray-700">
      <img
        src={imageSrc}
        alt={imageAlt || title}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-[1.03]"
        width="960"
        height="540"
      />
    </div>
  )}
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-base font-semibold tracking-tight line-clamp-2">
        {title}
      </h3>
      {date && (
        <span class="shrink-0 text-xs text-gray-500 dark:text-gray-400">
          {date}
        </span>
      )}
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="mt-1 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wide text-gray-600 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-400">
            {tag}
          </span>
        ))}
      </div>
    )}
    <div class="mt-3 flex items-center gap-1 text-sm font-medium text-primary hover:underline">
      <span>View project</span>
      <span
        aria-hidden="true"
        class="transition-transform duration-150 group-hover:translate-x-0.5"
      >
        →
      </span>
    </div>
  </div>
</a>

