---
import { getImageUrl } from "@/lib/cloudinary";
import { slugify } from "@/lib/slug";

interface Props {
  title: string
  description: string
  href: string
  imageSrc?: string
  imageAlt?: string
  tags?: string[]
  date?: string
  class?: string
}

const {
  title,
  description,
  href,
  imageSrc,
  imageAlt,
  tags = [],
  date,
  class: className,
} = Astro.props as Props

const resolvedImageSrc = imageSrc ? getImageUrl(imageSrc, { width: 960, quality: "auto:eco" }) : undefined;
---

<div
  class={`project-card group flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white text-gray-900 shadow-sm transition-all duration-150 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 ${className ?? ""}`}
>
  <a
    href={href}
    class="group flex min-h-0 flex-1 flex-col transition-all duration-150 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-xl"
  >
    {resolvedImageSrc && (
      <div class="relative aspect-[16/9] w-full shrink-0 overflow-hidden rounded-t-xl bg-gray-100 dark:bg-gray-700">
        <img
          src={resolvedImageSrc}
          alt={imageAlt || title}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-[1.03]"
          width="960"
          height="540"
        />
      </div>
    )}
    <div class="flex min-h-0 flex-1 flex-col gap-3 p-5">
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-base font-semibold tracking-tight text-gray-900 line-clamp-2 dark:text-gray-100">
          {title || 'Untitled project'}
        </h3>
        {date && (
          <span class="shrink-0 text-xs text-gray-500 dark:text-gray-400">
            {date}
          </span>
        )}
      </div>
      <p class="text-sm text-gray-600 line-clamp-3 dark:text-gray-400">
        {description || ' '}
      </p>
      <div class="mt-auto flex items-center gap-1 text-sm font-medium text-primary hover:underline">
        <span>View project</span>
        <span
          aria-hidden="true"
          class="transition-transform duration-150 group-hover:translate-x-0.5"
        >
          →
        </span>
      </div>
    </div>
  </a>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 border-t border-gray-100 px-5 py-3 dark:border-gray-700">
      {tags.map((tag) => (
        <a
          href={`/tags/${slugify(tag)}`}
          class="tag-pill rounded-full border border-gray-200 bg-gray-100 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wide text-gray-700 transition hover:border-primary hover:bg-primary/10 hover:text-primary dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300 dark:hover:border-primary dark:hover:bg-primary/20 dark:hover:text-primary"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</div>

